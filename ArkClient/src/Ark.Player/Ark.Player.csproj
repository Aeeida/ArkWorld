<Project Sdk="Godot.NET.Sdk/4.6.2">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!--
      These two lines will stop errors like this one:
      error CS0579: Duplicate 'global::System.Runtime.Versioning.TargetFrameworkAttribute' attribute
    -->
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
	</PropertyGroup>

	<ItemGroup>
	  <ProjectReference Include="..\Ark.Bridge\Ark.Bridge.csproj" />
	  <ProjectReference Include="..\Ark.Bridge.Building\Ark.Bridge.Building.csproj" />
	  <ProjectReference Include="..\Ark.Configuration\Ark.Configuration.csproj" />
	  <ProjectReference Include="..\Ark.Gameplay.Combat\Ark.Gameplay.Combat.csproj" />
	  <ProjectReference Include="..\Ark.Input\Ark.Input.csproj" />
	  <ProjectReference Include="..\Ark.Player.Character\Ark.Player.Character.csproj" />
	  <ProjectReference Include="..\Ark.Player.Vehicle\Ark.Player.Vehicle.csproj" />
	  <ProjectReference Include="..\Ark.UI\Ark.UI.csproj" />
	  <ProjectReference Include="..\Ark.Analyzers.Attributes\Ark.Analyzers.Attributes.csproj" />
	  <ProjectReference Include="..\Ark.Analyzers\Ark.Analyzers.csproj" ReferenceOutputAssembly="false" />
	</ItemGroup>

	<ItemGroup>
		<Analyzer Include="..\Ark.Analyzers\bin\$(Configuration)\netstandard2.0\Ark.Analyzers.dll" />
	</ItemGroup>

</Project>
