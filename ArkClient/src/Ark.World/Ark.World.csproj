<Project Sdk="Godot.NET.Sdk/4.6.2">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<!--
      These two lines will stop errors like this one:
      error CS0579: Duplicate 'global::System.Runtime.Versioning.TargetFrameworkAttribute' attribute
    -->
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
	</PropertyGroup>

	<ItemGroup>
	  <ProjectReference Include="..\Ark.Bridge\Ark.Bridge.csproj" />
	  <ProjectReference Include="..\Ark.Services\Ark.Services.csproj" />
	  <ProjectReference Include="..\Ark.Gameplay.Combat\Ark.Gameplay.Combat.csproj" />
	  <ProjectReference Include="..\Ark.World.Core\Ark.World.Core.csproj" />
	  <ProjectReference Include="..\Ark.World.Data\Ark.World.Data.csproj" />
	  <ProjectReference Include="..\Ark.World.Terrain\Ark.World.Terrain.csproj" />
	  <ProjectReference Include="..\Ark.World.Environment\Ark.World.Environment.csproj" />
	</ItemGroup>

</Project>
